STACK_NAME=ligolo-ng-aio
APP_NAME=ligolo-ng-aio
CONTAINER_NAME=ligolo-ng

# Versioning
LIGOLO_VERSION=latest
IMAGE_TAG=${LIGOLO_VERSION}

# Build References
WEBUI_REF=master

# Runtime Arguments
LIGOLO_ARGS=-nobanner -selfcert

# Networking
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000

## Advanced Networking (Change these only if you know what you're doing) ##
WEBUI_PORT_MAP=8000
AGENT_PORT_MAP=11601
API_HOST=127.0.0.1
API_PORT=8080
AGENT_HOST=0.0.0.0
AGENT_PORT=11601

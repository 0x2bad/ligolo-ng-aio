STACK_NAME=ligolo-ng-aio
APP_NAME=ligolo-ng-aio
CONTAINER_NAME=ligolo-ng

# Versioning
LIGOLO_VERSION=latest
IMAGE_TAG=${LIGOLO_VERSION}

# Build References
WEBUI_REF=master

# Runtime Arguments
LIGOLO_ARGS=-nobanner -selfcert

# Networking
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000
AGENT_HOST=0.0.0.0
AGENT_PORT=11601
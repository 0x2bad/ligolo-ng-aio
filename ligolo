#!/bin/bash

SCRIPT_PATH="$(readlink -f "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

cd "$SCRIPT_DIR" || { echo "Failed to change to script directory."; exit 1; }

if [[ ! -f "docker-compose.yaml" ]]; then
  echo "docker-compose.yaml not found in $SCRIPT_DIR."
  exit 1
fi

# feature flags
HOSTNET=0
CLI_BUILD=0

usage() {
  echo "Usage: $0 {start|stop|status|nsenter|attach} [--hostnet] [--cli] [--help|-h]"
  echo "  start      Start the container (use flags to select variant)"
  echo "  stop       Stop the container"
  echo "  status     Show container status"
  echo "  nsenter    Enter the container's network namespace (needed for bridge mode)"
  echo "  attach     Attach to the Ligolo-ng CLI"
  echo ""
  echo "  --help|-h  Show this help message"
  exit 1
}

if [[ $EUID -ne 0 ]]; then
  sudo "$0" "$@"
  exit $?
fi

command -v docker >/dev/null || { echo "Docker not found."; exit 1; }

if [[ $# -lt 1 ]]; then
  usage
fi

ACTION="$1"
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --hostnet)
      HOSTNET=1
      ;;
    --cli)
      CLI_BUILD=1
      ;;
    --help|-h)
      usage
      ;;
    *)
      usage
      ;;
  esac
  shift
done

if [[ $CLI_BUILD -eq 1 && $HOSTNET -eq 1 ]]; then
  PROFILE="cli-host"
elif [[ $CLI_BUILD -eq 1 ]]; then
  PROFILE="cli-bridge"
elif [[ $HOSTNET -eq 1 ]]; then
  PROFILE="full-host"
else
  PROFILE="full-bridge"
fi

case "$ACTION" in
  start)
    docker compose --profile "$PROFILE" up -d
    echo "Container started."
    ;;
  stop)
    docker compose --profile $(docker inspect $(docker compose ps --format '{{.Name}}') --format '{{ index .Config.Labels "com.docker.compose.service" }}' | rev | cut -d- -f1-2 | rev) down
    ;;
  status)
    docker compose ps -a
    ;;
  nsenter)
    command -v nsenter >/dev/null || { echo "nsenter not found (install util-linux)."; exit 1; }
    PID=$(docker inspect -f '{{.State.Pid}}' "$(docker compose ps --format '{{.Name}}')")
    if [[ -z "$PID" || "$PID" == "0" ]]; then
      echo "Container not running or not found."
      exit 1
    fi
    nsenter -t "$PID" -n bash
    ;;
  attach)
    docker compose attach $(docker compose ps --format '{{.Service}}')
    ;;
  *)
    usage
    ;;
esac

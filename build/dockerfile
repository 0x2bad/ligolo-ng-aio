FROM node:20-alpine AS webui-builder
ARG WEBUI_REF=master
ARG VITE_API_URL=""
ENV VITE_DEFAULT_API_URL=${VITE_API_URL}
WORKDIR /web
RUN apk add --no-cache git
RUN git clone --depth=1 --branch "${WEBUI_REF}" https://github.com/nicocha30/ligolo-ng-web.git .
RUN npm ci && npm run build 

FROM alpine:3.20 AS base
WORKDIR /opt/ligolo-ng
RUN apk add --no-cache tini ca-certificates iproute2 iptables curl gettext \
    && update-ca-certificates

ARG LIGOLO_VERSION=latest
RUN set -e; \
REPO="nicocha30/ligolo-ng"; TAG="${LIGOLO_VERSION:-latest}"; \
[ "$TAG" = latest ] && TAG="$(curl -fsSLI -o /dev/null \
-w '%{url_effective}' "https://github.com/$REPO/releases/latest" | \
sed -E 's#.*/tag/##')" ; \
ASSET="ligolo-ng_proxy_${TAG#?}_linux_amd64.tar.gz"; \
curl -fsSL --retry 3 "https://github.com/$REPO/releases/download/$TAG/$ASSET" \
| tar -xz -C /opt/ligolo-ng proxy \
&& rm -f $ASSET

COPY --chmod=0644 ./config/ligolo/ligolo-ng.yaml.tpl /opt/ligolo-ng/ligolo-ng.yaml.tpl
COPY --chmod=0755 ./entrypoint.sh /usr/local/bin/entrypoint.sh

ENV WEBUI_PORT=8000 \
    API_HOST=127.0.0.1 \
    API_PORT=11601 \
    LIGOLO_ARGS=""

EXPOSE 8000 11601
ENTRYPOINT ["/sbin/tini","--","/usr/local/bin/entrypoint.sh"]

FROM base AS full
RUN apk add --no-cache nginx
COPY --from=webui-builder /web/dist /usr/share/nginx/html
COPY --chmod=0644 ./config/nginx/nginx.conf /etc/nginx/nginx.conf

FROM base AS cli